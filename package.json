{
  "name": "dopetech-support-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:content": "tsx scripts/build-content.ts",
    "build:full": "npm run build:content && npm run build && npx tsx scripts/prerender.ts && npx tsx scripts/generate-sitemap.ts && npx pagefind --site dist",
    "preview": "vite preview",
    "deploy": "npm run build:full && npx wrangler pages deploy dist --project-name=dopetech-support --branch=main",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@notionhq/client": "^5.12.0",
    "clsx": "^2.1.1",
    "image-size": "^2.0.2",
    "lucide-react": "^0.474.0",
    "marked": "^17.0.4",
    "notion-to-md": "^3.1.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.1.1",
    "pagefind": "^1.4.0",
    "sanitize-html": "^2.17.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
